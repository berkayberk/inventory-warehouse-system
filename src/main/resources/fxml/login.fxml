<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.LoginController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color: #2c3e50; -fx-padding: 40;">

    <Label text="Inventory Warehouse IS" style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;"/>
    <Label text="Please log in" style="-fx-text-fill: #bdc3c7;"/>

    <TextField fx:id="usernameField" promptText="Username"
               maxWidth="260" style="-fx-pref-height: 36;"/>

    <PasswordField fx:id="passwordField" promptText="Password"
                   maxWidth="260" style="-fx-pref-height: 36;"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>

    <Button fx:id="loginButton" text="Log In"
            onAction="#handleLogin"
            defaultButton="true"
            maxWidth="260"
            styleClass="btn-primary"
            style="-fx-pref-height: 36;"/>
</VBox>
