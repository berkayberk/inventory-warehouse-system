<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.CashRegisterController"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10 16;" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="Cash Register" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Balance summary -->
            <HBox spacing="24" alignment="CENTER_LEFT">
                <Label text="Current Balance:" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                <Label fx:id="balanceLabel"    style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                <Label fx:id="thresholdLabel"  style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
            </HBox>

            <!-- Admin-only operations -->
            <TitledPane text="Deposit / Withdraw (Admin only)" fx:id="adminPane" collapsible="false">
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 12;">
                    <TextField fx:id="amountField" promptText="Amount" prefWidth="140"/>
                    <TextField fx:id="descriptionField" promptText="Description" prefWidth="260"/>
                    <Button text="Deposit"  onAction="#handleDeposit"  styleClass="btn-primary"/>
                    <Button text="Withdraw" onAction="#handleWithdraw" styleClass="btn-danger"/>
                </HBox>
            </TitledPane>

            <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true"/>

            <!-- Transaction history -->
            <Label text="Transaction History" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
            <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTxDate"    text="Date/Time"  prefWidth="160"/>
                    <TableColumn fx:id="colTxType"    text="Type"       prefWidth="100"/>
                    <TableColumn fx:id="colTxAmount"  text="Amount"     prefWidth="100"/>
                    <TableColumn fx:id="colTxDesc"    text="Description" prefWidth="260"/>
                    <TableColumn fx:id="colTxOperator" text="Operator" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
