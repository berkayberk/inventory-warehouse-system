<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.SupplierManagementController"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10 16;" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="Supplier Management" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.35">

            <!-- FORM -->
            <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #fff;">
                <Label text="Supplier Details" style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                <Label text="Name"/>
                <TextField fx:id="nameField" promptText="Company name"/>

                <Label text="Contact Person"/>
                <TextField fx:id="contactField" promptText="Contact name"/>

                <Label text="Phone"/>
                <TextField fx:id="phoneField" promptText="Phone number"/>

                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="Email address"/>

                <Label text="Address"/>
                <TextArea fx:id="addressArea" prefHeight="70" promptText="Full address" wrapText="true"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <CheckBox fx:id="activeCheck" text="Active"/>
                </HBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true"/>

                <HBox spacing="8">
                    <Button text="Save"   onAction="#handleSave"   styleClass="btn-primary"/>
                    <Button text="Clear"  onAction="#handleClear"  styleClass="btn-secondary"/>
                    <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                </HBox>
            </VBox>

            <!-- TABLE -->
            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #f9f9f9;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search by name…" prefWidth="220"/>
                    <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
                    <Button text="All"    onAction="#handleLoadAll" styleClass="btn-secondary"/>
                </HBox>
                <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"      prefWidth="50"/>
                        <TableColumn fx:id="colName"    text="Name"    prefWidth="200"/>
                        <TableColumn fx:id="colContact" text="Contact" prefWidth="140"/>
                        <TableColumn fx:id="colPhone"   text="Phone"   prefWidth="120"/>
                        <TableColumn fx:id="colActive"  text="Active"  prefWidth="70"/>
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
