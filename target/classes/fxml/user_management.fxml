<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.UserManagementController"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10 16;" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="User Management" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.35">

            <!-- LEFT: FORM -->
            <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #fff;">
                <Label text="User Details" style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                <Label text="Username"/>
                <TextField fx:id="usernameField" promptText="Enter username"/>

                <Label text="Password (leave blank to keep)"/>
                <PasswordField fx:id="passwordField" promptText="Enter password"/>

                <Label text="Full Name"/>
                <TextField fx:id="fullNameField" promptText="Enter full name"/>

                <Label text="Email"/>
                <TextField fx:id="emailField" promptText="Enter email"/>

                <Label text="Role"/>
                <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <CheckBox fx:id="activeCheck" text="Active"/>
                </HBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true"/>

                <HBox spacing="8">
                    <Button text="Save"   onAction="#handleSave"   styleClass="btn-primary"/>
                    <Button text="Clear"  onAction="#handleClear"  styleClass="btn-secondary"/>
                    <Button text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                </HBox>
            </VBox>

            <!-- RIGHT: TABLE -->
            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #f9f9f9;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search…" prefWidth="220"/>
                    <Button text="Search" onAction="#handleSearch" styleClass="btn-primary"/>
                    <Button text="All"    onAction="#handleLoadAll" styleClass="btn-secondary"/>
                </HBox>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"       prefWidth="50"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="130"/>
                        <TableColumn fx:id="colFullName" text="Full Name" prefWidth="160"/>
                        <TableColumn fx:id="colRole"     text="Role"     prefWidth="90"/>
                        <TableColumn fx:id="colActive"   text="Active"   prefWidth="70"/>
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
