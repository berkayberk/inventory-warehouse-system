<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.InvoiceListController"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10 16;" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button text="← Back" onAction="#goBack" styleClass="btn-secondary"/>
                <Label text="Invoice List" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <RadioButton fx:id="rbAll"      text="All"       toggleGroup="$filterGroup" style="-fx-text-fill: white;" selected="true"/>
                <RadioButton fx:id="rbPurchase" text="Purchase"  toggleGroup="$filterGroup" style="-fx-text-fill: white;"/>
                <RadioButton fx:id="rbSale"     text="Sale"      toggleGroup="$filterGroup" style="-fx-text-fill: white;"/>
                <fx:define>
                    <ToggleGroup fx:id="filterGroup"/>
                </fx:define>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 16;">
            <!-- Invoices -->
            <Label text="Invoices" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
            <TableView fx:id="invoiceTable" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colInvNumber"   text="Number"     prefWidth="150"/>
                    <TableColumn fx:id="colInvType"     text="Type"       prefWidth="90"/>
                    <TableColumn fx:id="colInvDate"     text="Date"       prefWidth="140"/>
                    <TableColumn fx:id="colInvParty"    text="Supplier/Client" prefWidth="180"/>
                    <TableColumn fx:id="colInvOperator" text="Operator"   prefWidth="130"/>
                    <TableColumn fx:id="colInvTotal"    text="Total"      prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Items detail -->
            <Label text="Invoice Items" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colItemGood"     text="Product"   prefWidth="220"/>
                    <TableColumn fx:id="colItemQty"      text="Qty"       prefWidth="80"/>
                    <TableColumn fx:id="colItemUnit"     text="Unit"      prefWidth="70"/>
                    <TableColumn fx:id="colItemPrice"    text="Unit Price" prefWidth="100"/>
                    <TableColumn fx:id="colItemSubtotal" text="Subtotal"  prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
