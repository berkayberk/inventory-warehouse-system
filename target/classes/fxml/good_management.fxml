<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.GoodManagementController"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10 16;" alignment="CENTER_LEFT" spacing="12">
            <Button text="← Back" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="Goods Management" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.38">

            <!-- FORM -->
            <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #fff;">
                <Label text="Good Details" style="-fx-font-size: 14; -fx-font-weight: bold;"/>

                <Label text="Name"/>
                <TextField fx:id="nameField" promptText="Product name"/>

                <Label text="Category"/>
                <TextField fx:id="categoryField" promptText="Category"/>

                <Label text="Unit"/>
                <TextField fx:id="unitField" promptText="pcs / kg / L …"/>

                <Label text="Delivery Price"/>
                <TextField fx:id="deliveryPriceField" promptText="0.00"/>

                <Label text="Sales Price"/>
                <TextField fx:id="salesPriceField" promptText="0.00"/>

                <Label text="Quantity"/>
                <TextField fx:id="quantityField" promptText="0"/>

                <Label text="Min Threshold"/>
                <TextField fx:id="minThresholdField" promptText="0"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <CheckBox fx:id="activeCheck" text="Active"/>
                </HBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c;" wrapText="true"/>

                <HBox fx:id="adminButtons" spacing="8">
                    <Button fx:id="saveButton"   text="Save"   onAction="#handleSave"   styleClass="btn-primary"/>
                    <Button text="Clear"  onAction="#handleClear"  styleClass="btn-secondary"/>
                    <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                </HBox>
            </VBox>

            <!-- TABLE -->
            <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #f9f9f9;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search by name or category…" prefWidth="240"/>
                    <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
                    <Button text="All"    onAction="#handleLoadAll" styleClass="btn-secondary"/>
                </HBox>
                <TableView fx:id="goodTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"            text="ID"       prefWidth="50"/>
                        <TableColumn fx:id="colName"          text="Name"     prefWidth="180"/>
                        <TableColumn fx:id="colCategory"      text="Category" prefWidth="120"/>
                        <TableColumn fx:id="colUnit"          text="Unit"     prefWidth="70"/>
                        <TableColumn fx:id="colDeliveryPrice" text="Cost"     prefWidth="90"/>
                        <TableColumn fx:id="colSalesPrice"    text="Price"    prefWidth="90"/>
                        <TableColumn fx:id="colQty"           text="Qty"      prefWidth="70"/>
                        <TableColumn fx:id="colStatus"        text="Status"   prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
